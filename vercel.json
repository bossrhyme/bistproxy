{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https://*.tradingview.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://s3.tradingview.com https://*.tradingview.com https://unpkg.com https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.tradingview.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.coingecko.com https://www.tefas.gov.tr https://finnhub.io https://*.tradingview.com https://query1.finance.yahoo.com https://cdn.jsdelivr.net https://fonts.googleapis.com https://fonts.gstatic.com; frame-ancestors 'none'; frame-src https://s3.tradingview.com https://s.tradingview.com https://www.tradingview.com https://*.tradingview.com https://widget.tradingview.com; worker-src 'self';"
        }
      ]
    },
    {
      "source": "/(deepfin|analiz/prf|analiz/analiz)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable, s-maxage=0"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/(|index\\.html|screener|analiz/|analiz/index\\.html|analiz/profil\\.html|analiz/profile\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/screener",
      "destination": "/"
    },
    {
      "source": "/api/scan",
      "destination": "/api/scan.js"
    },
    {
      "source": "/api/quote",
      "destination": "/api/quote.js"
    },
    {
      "source": "/api/rates",
      "destination": "/api/rates.js"
    },
    {
      "source": "/analiz",
      "destination": "/analiz/index.html"
    },
    {
      "source": "/analiz/",
      "destination": "/analiz/index.html"
    },
    {
      "source": "/analiz/profil",
      "destination": "/analiz/profil.html"
    },
    {
      "source": "/analiz/profil/",
      "destination": "/analiz/profil.html"
    },
    {
      "source": "/api/verify",
      "destination": "/api/verify.js"
    },
    {
      "source": "/api/fundamentals",
      "destination": "/api/fundamentals.js"
    },
    {
      "source": "/api/fon-scan",
      "destination": "/api/fon-scan.js"
    },
    {
      "source": "/api/kripto-scan",
      "destination": "/api/kripto-scan.js"
    },
    {
      "source": "/api/bist-scan",
      "destination": "/api/bist-scan.js"
    },
    {
      "source": "/api/bist-quote",
      "destination": "/api/bist-quote.js"
    },
    {
      "source": "/api/symbol-list",
      "destination": "/api/symbol-list.js"
    },
    {
      "source": "/api/symbol-search",
      "destination": "/api/symbol-search.js"
    }
  ],
  "functions": {
    "api/verify.js": {
      "maxDuration": 10
    },
    "api/fundamentals.js": {
      "maxDuration": 15
    },
    "api/fon-scan.js": {
      "maxDuration": 45
    },
    "api/kripto-scan.js": {
      "maxDuration": 20
    },
    "api/bist-scan.js": {
      "maxDuration": 15
    },
    "api/bist-quote.js": {
      "maxDuration": 10
    },
    "api/symbol-list.js": {
      "maxDuration": 15
    },
    "api/symbol-search.js": {
      "maxDuration": 10
    }
  }
}